# ============================================
# ВИРТУАЛЬНЫЕ ОКРУЖЕНИЯ
# ============================================
# Эти папки создаются Python для изоляции зависимостей
# Они занимают много места и должны быть уникальными для каждого компьютера
venv/           # Стандартное имя виртуального окружения (Python venv)
env/            # Альтернативное имя для виртуального окружения
ENV/            # Еще один вариант имени (часто в Windows)
.venv/          # Скрытая папка виртуального окружения (популярно в VS Code)

# ============================================
# PYTHON - СЛУЖЕБНЫЕ ФАЙЛЫ
# ============================================
__pycache__/    # Кэш байт-кода Python (ускоряет запуск, но не нужен в репозитории)
*.py[cod]       # Скомпилированные файлы: .pyc, .pyo, .pyd
*$py.class      # Файлы классов Python (PyPy, Jython)
*.so            # Скомпилированные C-расширения для Python (Unix)
.Python         # Файлы сборки Python

# ============================================
# PYTHON - УСТАНОВКА ПАКЕТОВ
# ============================================
*.egg-info/     # Метаданные установленного пакета (создается pip install)
dist/           # Папка с собранными дистрибутивами (pip install --build)
build/          # Временные файлы сборки (python setup.py build)

# ============================================
# СРЕДЫ РАЗРАБОТКИ (IDE)
# ============================================
.vscode/        # Папка настроек VS Code (личные настройки разработчика)
.idea/          # Папка настроек PyCharm/IntelliJ IDEA
*.swp           # Временные файлы Vim (swap files)
*.swo           # Другие временные файлы Vim
.DS_Store       # Служебные файлы macOS (информация о папках, иконки)

# ============================================
# ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ (СЕКРЕТЫ)
# ============================================
# Файлы с конфиденциальными данными (пароли, ключи API)
.env            # Основной файл с секретами (НИКОГДА не пушить!)
.env.local      # Локальные настройки (для конкретного компьютера)
.env.*.local    # Любые локальные файлы окружения (.env.development.local и т.д.)

# ============================================
# ЛОГИ
# ============================================
*.log           # Все файлы логов (отслеживают работу программы)
logs/           # Папка с логами (обычно создается автоматически)

# ============================================
# ДАННЫЕ (опционально)
# ============================================
# Исключаем ВСЕ файлы в input и output...
data/input/*    # Все файлы во входных данных (могут быть большими)
data/output/*   # Все файлы в выходных данных (генерируются при работе)

# ...НО сохраняем структуру папок с помощью .gitkeep
!data/input/.gitkeep      # Исключение: сохраняем пустой файл-заглушку
!data/output/.gitkeep     # Исключение: сохраняем пустой файл-заглушку

# ============================================
# ОПЕРАЦИОННЫЕ СИСТЕМЫ
# ============================================
Thumbs.db       # Файлы миниатюр Windows (создаются автоматически)
.DS_Store       # Файлы macOS (повторяем для уверенности)